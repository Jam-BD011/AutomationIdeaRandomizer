<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane fx:id="ideaSceneStack" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="300.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.AtmIdeaRndo.model.IdeasScreenController">
   <children>
      <BorderPane fx:id="ideaSceneBorder" prefHeight="200.0" prefWidth="200.0">
         <top>
            <ToolBar fx:id="topToolBar" nodeOrientation="LEFT_TO_RIGHT" prefHeight="30.0" prefWidth="600.0" BorderPane.alignment="CENTER">
               <items>
                  <Button fx:id="exitBtn" mnemonicParsing="false" onAction="#exitProgram" text="Exit" />
                  <Button fx:id="homeBtn" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#goHome" prefHeight="25.0" prefWidth="107.0" text="Home" textAlignment="CENTER">
                     <opaqueInsets>
                        <Insets />
                     </opaqueInsets>
                  </Button>
               </items>
               <BorderPane.margin>
                  <Insets />
               </BorderPane.margin>
            </ToolBar>
         </top>
         <center>
            <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0" BorderPane.alignment="CENTER">
               <children>
                  <Label fx:id="listLabel" text="Currently Generated Ideas">
                     <VBox.margin>
                        <Insets bottom="5.0" top="-10.0" />
                     </VBox.margin>
                  </Label>
                  <ListView fx:id="ideasList" prefHeight="183.0" prefWidth="500.0">
                     <VBox.margin>
                        <Insets left="50.0" right="50.0" />
                     </VBox.margin>
                  </ListView>
               </children>
            </VBox>
         </center>
         <bottom>
            <VBox alignment="CENTER" prefHeight="13.0" prefWidth="600.0" BorderPane.alignment="CENTER">
               <children>
                  <HBox alignment="CENTER" prefHeight="25.0" prefWidth="600.0">
                     <children>
                        <Button fx:id="removeItem" mnemonicParsing="false" onAction="#removeIdea" text="Remove Selected Item" translateY="-10.0">
                           <HBox.margin>
                              <Insets right="10.0" />
                           </HBox.margin>
                        </Button>
                        <Button fx:id="exportBtn" alignment="CENTER" mnemonicParsing="false" onAction="#exportIdeasToTextFile" text="Export to Text File" translateY="-10.0">
                           <opaqueInsets>
                              <Insets />
                           </opaqueInsets>
                        </Button>
                        <Button fx:id="openExportFile" disable="true" mnemonicParsing="false" onAction="#openExportFile" text="Open Export File" translateY="-10.0">
                           <HBox.margin>
                              <Insets left="10.0" />
                           </HBox.margin>
                        </Button>
                     </children>
                  </HBox>
                  <Label fx:id="exportConfirmationLabel" alignment="CENTER" textAlignment="CENTER" />
               </children>
            </VBox>
         </bottom>
      </BorderPane>
   </children>
</StackPane>
